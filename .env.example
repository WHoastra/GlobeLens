# ============================================================
# GlobeLens — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your keys.
#   cp .env.example .env.local
# ============================================================

# ── World News API ──────────────────────────────────────────
# Get a key at: https://worldnewsapi.com/
WORLD_NEWS_API_KEY=

# ── Anthropic / Claude AI ──────────────────────────────────
# Used for intelligent geotagging of news articles.
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Supabase ───────────────────────────────────────────────
# Used for caching news and weather data.
# Create a project at: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Mapbox ─────────────────────────────────────────────────
# Used for high-res globe imagery tiles.
# Get a token at: https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── Windy Webcams ──────────────────────────────────────────
# Used for the live webcam layer.
# Get a key at: https://api.windy.com/
WINDY_WEBCAMS_API_KEY=

# ── TomTom Traffic ─────────────────────────────────────────
# Used for the traffic incidents layer.
# Get a key at: https://developer.tomtom.com/
TOMTOM_API_KEY=

# ── OpenWeatherMap ─────────────────────────────────────────
# Used for weather tile overlays (clouds, precipitation, temp, wind).
# Get a key at: https://openweathermap.org/api
NEXT_PUBLIC_OPENWEATHERMAP_API_KEY=

# ── Free APIs (no key required) ────────────────────────────
# GDELT Project  — https://api.gdeltproject.org/
# Open-Meteo     — https://open-meteo.com/
# These are free and keyless. No env vars needed.
